"""
Data Fetcher - Live NSE data with 15+ technical indicators
Uses yfinance for data, pandas-ta for indicators
"""

import yfinance as yf
import pandas as pd
import numpy as np
from datetime import datetime, timedelta
import streamlit as st
import warnings
warnings.filterwarnings('ignore')

# Cache timeout in seconds
CACHE_TTL = 300  # 5 minutes

@st.cache_data(ttl=CACHE_TTL)
def fetch_stock_data(symbol: str, period: str = "6mo", interval: str = "1d") -> pd.DataFrame:
    """
    Fetch OHLCV data for a given NSE stock symbol.
    
    Args:
        symbol: NSE symbol (e.g., 'RELIANCE.NS')
        period: Data period ('1mo', '3mo', '6mo', '1y', '2y', '5y')
        interval: Data interval ('1d', '1wk', '1mo')
    
    Returns:
        DataFrame with OHLCV data + technical indicators
    """
    try:
        ticker = yf.Ticker(symbol)
        df = ticker.history(period=period, interval=interval)
        
        if df.empty:
            return pd.DataFrame()
        
        # Clean column names
        df.columns = [c.lower() for c in df.columns]
        df.index = pd.to_datetime(df.index)
        df = df.dropna()
        
        # Add technical indicators
        df = add_technical_indicators(df)
        
        return df
    except Exception as e:
        st.error(f"Error fetching data for {symbol}: {e}")
        return pd.DataFrame()


@st.cache_data(ttl=CACHE_TTL)
def fetch_stock_info(symbol: str) -> dict:
    """Fetch stock metadata and fundamentals"""
    try:
        ticker = yf.Ticker(symbol)
        info = ticker.info
        
        return {
            "name": info.get("longName", info.get("shortName", symbol)),
            "sector": info.get("sector", "N/A"),
            "industry": info.get("industry", "N/A"),
            "market_cap": info.get("marketCap", 0),
            "pe_ratio": info.get("trailingPE", None),
            "pb_ratio": info.get("priceToBook", None),
            "dividend_yield": info.get("dividendYield", None),
            "52w_high": info.get("fiftyTwoWeekHigh", None),
            "52w_low": info.get("fiftyTwoWeekLow", None),
            "avg_volume": info.get("averageVolume", None),
            "beta": info.get("beta", None),
            "eps": info.get("trailingEps", None),
            "revenue": info.get("totalRevenue", None),
            "profit_margin": info.get("profitMargins", None),
            "roe": info.get("returnOnEquity", None),
